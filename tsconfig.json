{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./backend/src"
  },
  "include": ["backend/src/**/*.ts", "backend/test/**/*.ts"],
  "exclude": ["node_modules", "dist", "frontend"]
}